{
  "name": "website-visual-test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Configurable Playwright visual comparison framework for comparing two website domains page by page.",
  "scripts": {
    "preflight": "tsx src/cli/preflight.ts",
    "visual:ui": "tsx src/server/app.ts",
    "visual:urls": "tsx src/cli/urls.ts",
    "visual:crawl": "tsx src/cli/crawl.ts",
    "visual:test": "tsx src/cli/test.ts",
    "visual:report": "tsx src/cli/report.ts",
    "visual:all": "tsx src/cli/all.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck"
  },
  "dependencies": {
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.20.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  }
}
